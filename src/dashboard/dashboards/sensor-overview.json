{
  "uid": "sensor-overview",
  "title": "Sensor Overview — Factory Floor",
  "description": "Live sensor readings, statistics, and recent data from factory floor sensors.",
  "tags": ["sensors", "factory", "aio"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "templating": {
    "list": [
      {
        "name": "sensor_id",
        "label": "Sensor ID",
        "type": "custom",
        "query": "sensor-001,sensor-002,sensor-003,sensor-004,sensor-005",
        "current": {
          "text": "sensor-001",
          "value": "sensor-001"
        },
        "options": [
          { "text": "sensor-001", "value": "sensor-001", "selected": true },
          { "text": "sensor-002", "value": "sensor-002", "selected": false },
          { "text": "sensor-003", "value": "sensor-003", "selected": false },
          { "text": "sensor-004", "value": "sensor-004", "selected": false },
          { "text": "sensor-005", "value": "sensor-005", "selected": false }
        ],
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "time_range",
        "label": "Time Range",
        "type": "interval",
        "query": "5m,15m,30m,1h,6h,12h,24h",
        "current": {
          "text": "1h",
          "value": "1h"
        },
        "options": [
          { "text": "5m", "value": "5m", "selected": false },
          { "text": "15m", "value": "15m", "selected": false },
          { "text": "30m", "value": "30m", "selected": false },
          { "text": "1h", "value": "1h", "selected": true },
          { "text": "6h", "value": "6h", "selected": false },
          { "text": "12h", "value": "12h", "selected": false },
          { "text": "24h", "value": "24h", "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Live Sensor Readings",
      "id": 1,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Vibration",
      "type": "timeseries",
      "datasource": { "type": "grafana-mqtt-datasource", "uid": "mqtt" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Vibration",
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false
          },
          "unit": "accMS2",
          "displayName": "Vibration (m/s²)"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-mqtt-datasource", "uid": "mqtt" },
          "topic": "sensors/${sensor_id}/vibration"
        }
      ]
    },
    {
      "id": 3,
      "title": "Temperature",
      "type": "timeseries",
      "datasource": { "type": "grafana-mqtt-datasource", "uid": "mqtt" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Temperature",
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false
          },
          "unit": "celsius",
          "displayName": "Temperature (°C)"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-mqtt-datasource", "uid": "mqtt" },
          "topic": "sensors/${sensor_id}/temperature"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pressure",
      "type": "timeseries",
      "datasource": { "type": "grafana-mqtt-datasource", "uid": "mqtt" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Pressure",
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false
          },
          "unit": "pressurebar",
          "displayName": "Pressure (bar)"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-mqtt-datasource", "uid": "mqtt" },
          "topic": "sensors/${sensor_id}/pressure"
        }
      ]
    },
    {
      "type": "row",
      "title": "Sensor Statistics",
      "id": 5,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 6,
      "title": "Vibration — Min / Max / Avg",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "accMS2"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["min", "max", "mean"],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sensor_vibration{sensor_id=\"${sensor_id}\"}",
          "legendFormat": "Vibration"
        }
      ]
    },
    {
      "id": 7,
      "title": "Temperature — Min / Max / Avg",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["min", "max", "mean"],
          "fields": "",
          "values": false
        },
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sensor_temperature{sensor_id=\"${sensor_id}\"}",
          "legendFormat": "Temperature"
        }
      ]
    },
    {
      "id": 8,
      "title": "Current Pressure",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 160 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "pressurebar",
          "min": 0,
          "max": 300
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sensor_pressure{sensor_id=\"${sensor_id}\"}",
          "legendFormat": "Pressure"
        }
      ]
    },
    {
      "type": "row",
      "title": "Recent Data Table",
      "id": 9,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "id": 10,
      "title": "Latest Sensor Readings",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sensor_id" },
            "properties": [
              { "id": "displayName", "value": "Sensor ID" },
              { "id": "custom.width", "value": 150 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "vibration" },
            "properties": [
              { "id": "displayName", "value": "Vibration (m/s²)" },
              { "id": "unit", "value": "accMS2" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "temperature" },
            "properties": [
              { "id": "displayName", "value": "Temperature (°C)" },
              { "id": "unit", "value": "celsius" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pressure" },
            "properties": [
              { "id": "displayName", "value": "Pressure (bar)" },
              { "id": "unit", "value": "pressurebar" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "displayName", "value": "Timestamp" },
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Timestamp", "desc": true }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "Time", "order": "desc" }] }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sensor_vibration",
          "legendFormat": "{{sensor_id}}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sensor_temperature",
          "legendFormat": "{{sensor_id}}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sensor_pressure",
          "legendFormat": "{{sensor_id}}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
